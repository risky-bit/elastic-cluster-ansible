agent:
  monitoring:
    enabled: true
    use_output: default
    logs: true
    metrics: true

outputs:
  default:
    type: elasticsearch
    hosts:
{% for host in groups['monitoring_nodes'] %}
      - "https://{{ hostvars[host]['bind_ip'] }}:{{ http_port }}"
{% endfor %}
    username: elastic
    password: "{{ mon_elastic_password }}"
    ssl:
      certificate_authorities:
        - /etc/elasticsearch/certificates/ca.crt

inputs:

  # ---------------------------------------------------------------
  # Elasticsearch metrics — node-level (all nodes)
  # ---------------------------------------------------------------
  - id: elasticsearch-node-metrics-{{ inventory_hostname }}
    type: elasticsearch/metrics
    use_output: default
    data_stream:
      namespace: default
    streams:
      - metricset: node_stats
        data_stream:
          dataset: elasticsearch.stack_monitoring.node_stats
          type: metrics
        period: 10s
        hosts:
          - "https://{{ bind_ip }}:{{ http_port }}"
        username: elastic
        password: "{{ elastic_password }}"
        ssl:
          certificate_authorities:
            - /etc/elasticsearch/certificates/ca.crt

{% if inventory_hostname in groups['elastic_master_nodes'] %}
  # ---------------------------------------------------------------
  # Elasticsearch metrics — cluster-level (masters only)
  # ---------------------------------------------------------------
  - id: elasticsearch-cluster-metrics-{{ inventory_hostname }}
    type: elasticsearch/metrics
    use_output: default
    data_stream:
      namespace: default
    streams:
      - metricset: cluster_stats
        data_stream:
          dataset: elasticsearch.stack_monitoring.cluster_stats
          type: metrics
        period: 10s
        scope: cluster
        hosts:
          - "https://{{ bind_ip }}:{{ http_port }}"
        username: elastic
        password: "{{ elastic_password }}"
        ssl:
          certificate_authorities:
            - /etc/elasticsearch/certificates/ca.crt

      - metricset: index
        data_stream:
          dataset: elasticsearch.stack_monitoring.index
          type: metrics
        period: 30s
        hosts:
          - "https://{{ bind_ip }}:{{ http_port }}"
        username: elastic
        password: "{{ elastic_password }}"
        ssl:
          certificate_authorities:
            - /etc/elasticsearch/certificates/ca.crt

{% endif %}

  # ---------------------------------------------------------------
  # System metrics (all nodes)
  # ---------------------------------------------------------------
  - id: system-metrics-{{ inventory_hostname }}
    type: system/metrics
    use_output: default
    data_stream:
      namespace: default
    streams:
      - metricset: cpu
        data_stream:
          dataset: system.cpu
          type: metrics
        period: 10s
      - metricset: memory
        data_stream:
          dataset: system.memory
          type: metrics
        period: 10s
      - metricset: filesystem
        data_stream:
          dataset: system.filesystem
          type: metrics
        period: 1m
      - metricset: diskio
        data_stream:
          dataset: system.diskio
          type: metrics
        period: 10s
      - metricset: load
        data_stream:
          dataset: system.load
          type: metrics
        period: 10s
      - metricset: network
        data_stream:
          dataset: system.network
          type: metrics
        period: 10s
      - metricset: process
        data_stream:
          dataset: system.process
          type: metrics
        period: 10s
        process.include_top_n.by_cpu: 5
        process.include_top_n.by_memory: 5

  # ---------------------------------------------------------------
  # Elasticsearch logs (all nodes)
  # ---------------------------------------------------------------
  - id: elasticsearch-logs-{{ inventory_hostname }}
    type: filestream
    use_output: default
    data_stream:
      namespace: default
    streams:
      - id: elasticsearch-server-logs
        data_stream:
          dataset: elasticsearch.server
          type: logs
        paths:
          - /var/log/elasticsearch/*.log
        exclude_files:
          - .gz$
        parsers:
          - ndjson:
              message_key: message
              target: ""
              ignore_decoding_error: true
