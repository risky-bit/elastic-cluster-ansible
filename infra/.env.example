SEMAPHORE_IMAGE=semaphoreui/semaphore:v2.17.37-ansible2.16.5
SEMAPHORE_POSTGRES_IMAGE=postgres:16-alpine
SEMAPHORE_HTTP_PORT=3000
SEMAPHORE_DB=semaphore
SEMAPHORE_DB_USER=semaphore
SEMAPHORE_DB_PASSWORD=change-me
SEMAPHORE_ACCESS_KEY_ENCRYPTION=change-me-change-me-change-me-change-me
