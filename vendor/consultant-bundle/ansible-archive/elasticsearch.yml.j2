# Enable security features
xpack.security.enabled: true

xpack.security.enrollment.enabled: true

xpack.security.transport.ssl.enabled: true
xpack.security.transport.ssl.verification_mode: certificate
xpack.security.transport.ssl.client_authentication: none
xpack.security.transport.ssl.keystore.path: certificates/certfile.p12
#xpack.security.transport.ssl.key: certificates/new-es.key
#xpack.security.transport.ssl.certificate: certificates/new-es.crt
#xpack.security.transport.ssl.certificate_authorities: [ "certificates/new-ca.crt" ]

xpack.security.http.ssl.enabled: true
xpack.security.http.ssl.client_authentication: none
xpack.security.http.ssl.keystore.path: certificates/certfile.p12
#xpack.security.http.ssl.key: certificates/new-es.key
#xpack.security.http.ssl.certificate: certificates/new-es.crt
#xpack.security.http.ssl.certificate_authorities: [ "certificates/new-ca.crt" ]

xpack.monitoring.collection.enabled: true

# Allow HTTP API connections from anywhere
# Connections are encrypted and require user authentication
http.host: 0.0.0.0

# Allow other nodes to join the cluster from anywhere
# Connections are encrypted and mutually authenticated
transport.host: 0.0.0.0

